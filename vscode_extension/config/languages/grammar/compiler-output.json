{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Delphi Compiler Output",
  "scopeName": "text.output.delphi-compiler",
  "patterns": [
    {
      "comment": "Compiler diagnostic line: time: [SEVERITY][CODE] file:line(:col)? - message",
      "name": "meta.compiler-message.delphi",
      "match": "^(\\S+?):\\s+(\\[(ERROR|WARN|INFO|HINT)\\])(\\[[A-Z]\\d+\\])\\s+((?:[A-Za-z]:|/)[^:]+):(\\d+)(?::(\\d+))?\\s+-\\s+(.*)$",
      "captures": {
        "1": {
          "name": "constant.other.timestamp.delphi"
        },
        "2": {
          "name": "keyword.control.severity.delphi",
          "patterns": [
            {
              "match": "\\[ERROR\\]",
              "name": "invalid.illegal.error.delphi"
            },
            {
              "match": "\\[WARN\\]",
              "name": "markup.warning.delphi"
            },
            {
              "match": "\\[INFO\\]",
              "name": "markup.info.delphi"
            },
            {
              "match": "\\[HINT\\]",
              "name": "markup.hint.delphi"
            }
          ]
        },
        "4": {
          "name": "constant.other.error-code.delphi"
        },
        "5": {
          "name": "string.other.filepath.delphi"
        },
        "6": {
          "name": "constant.numeric.line-number.delphi"
        },
        "7": {
          "name": "constant.numeric.column-number.delphi"
        },
        "8": {
          "name": "string.unquoted.message.delphi",
          "patterns": [
            {
              "match": "'[^\\s']+'",
              "name": "entity.name.type.quoted-identifier.delphi"
            }
          ]
        }
      }
    },
    {
      "comment": "Success banner (uses heavy box-drawing: ┏━┓ / ┗━┛)",
      "name": "markup.success.banner.delphi",
      "begin": "\u250f",
      "end": "\u251b",
      "beginCaptures": {
        "0": { "name": "markup.success.banner.delphi" }
      },
      "endCaptures": {
        "0": { "name": "markup.success.banner.delphi" }
      },
      "patterns": [
        {
          "match": ".",
          "name": "markup.success.banner.delphi"
        }
      ]
    },
    {
      "comment": "Error banner (uses double box-drawing: ╔═╗ / ╚═╝)",
      "name": "markup.error.banner.delphi",
      "begin": "\u2554",
      "end": "\u255d",
      "beginCaptures": {
        "0": { "name": "markup.error.banner.delphi" }
      },
      "endCaptures": {
        "0": { "name": "markup.error.banner.delphi" }
      },
      "patterns": [
        {
          "match": ".",
          "name": "markup.error.banner.delphi"
        }
      ]
    },
    {
      "comment": "Cancelled banner (uses mixed box-drawing: ╓─╖ / ╙─╜)",
      "name": "markup.cancelled.banner.delphi",
      "begin": "\u2553",
      "end": "\u255c",
      "beginCaptures": {
        "0": { "name": "markup.cancelled.banner.delphi" }
      },
      "endCaptures": {
        "0": { "name": "markup.cancelled.banner.delphi" }
      },
      "patterns": [
        {
          "match": ".",
          "name": "markup.cancelled.banner.delphi"
        }
      ]
    },
    {
      "comment": "Multi-project main banner (uses light+heavy: ┍━┑ / ┕━┙)",
      "name": "markup.multi.banner.delphi",
      "begin": "\u250d",
      "end": "\u2519",
      "beginCaptures": {
        "0": { "name": "markup.multi.banner.delphi" }
      },
      "endCaptures": {
        "0": { "name": "markup.multi.banner.delphi" }
      },
      "patterns": [
        {
          "match": ".",
          "name": "markup.multi.banner.delphi"
        }
      ]
    },
    {
      "comment": "Individual project banner within multi (uses light: ┌─┐ / └─┘)",
      "name": "markup.project.banner.delphi",
      "begin": "\u250c",
      "end": "\u2518",
      "beginCaptures": {
        "0": { "name": "markup.project.banner.delphi" }
      },
      "endCaptures": {
        "0": { "name": "markup.project.banner.delphi" }
      },
      "patterns": [
        {
          "match": ".",
          "name": "markup.project.banner.delphi"
        }
      ]
    },
    {
      "comment": "Normal banner (uses single/double box-drawing: ╒═╕ / ╘═╛)",
      "name": "keyword.other.banner.delphi",
      "begin": "\u2552",
      "end": "\u255b",
      "beginCaptures": {
        "0": { "name": "keyword.other.banner.delphi" }
      },
      "endCaptures": {
        "0": { "name": "keyword.other.banner.delphi" }
      },
      "patterns": [
        {
          "match": ".",
          "name": "keyword.other.banner.delphi"
        }
      ]
    }
  ]
}