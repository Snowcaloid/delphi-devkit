{
  "$schema": "vscode://schemas/color-theme",
  "name": "Delphi Compiler Colors",
  "type": "dark",
  "tokenColors": [
    {
      "scope": "invalid.illegal.error.delphi",
      "settings": {
        "foreground": "#ff6b6b"
      }
    },
    {
      "scope": "markup.warning.delphi",
      "settings": {
        "foreground": "#fdcb6e"
      }
    },
    {
      "scope": "markup.hint.delphi",
      "settings": {
        "foreground": "#74b9ff"
      }
    },
    {
      "scope": "markup.info.delphi",
      "settings": {
        "foreground": "#55a3ff"
      }
    },
    {
      "scope": "constant.other.error-code.delphi",
      "settings": {
        "foreground": "#a29bfe"
      }
    },
    {
      "scope": "string.other.filepath.delphi",
      "settings": {
        "foreground": "#00b894"
      }
    },
    {
      "scope": "constant.numeric.line-number.delphi, constant.numeric.column-number.delphi",
      "settings": {
        "foreground": "#ffeaa7"
      }
    },
    {
      "scope": "constant.other.timestamp.delphi",
      "settings": {
        "foreground": "#636e72"
      }
    },
    {
      "scope": "string.unquoted.message.delphi",
      "settings": {
        "foreground": "#dfe6e9"
      }
    },
    {
      "scope": "entity.name.type.quoted-identifier.delphi",
      "settings": {
        "foreground": "#e17cf5",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "keyword.other.banner.delphi",
      "settings": {
        "foreground": "#74b9ff"
      }
    },
    {
      "scope": "markup.success.banner.delphi",
      "settings": {
        "foreground": "#00b894"
      }
    },
    {
      "scope": "markup.error.banner.delphi",
      "settings": {
        "foreground": "#ff6b6b"
      }
    }
  ]
}
