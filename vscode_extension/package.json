{
  "name": "delphi-devkit",
  "displayName": "DDK - Delphi Development Kit",
  "description": "Utilities for developing in Delphi using VS Code",
  "version": "2.1.1",
  "publisher": "Snowcaloid",
  "license": "SEE LICENSE IN LICENSE",
  "homepage": "https://www.github.com/valentin-baron",
  "repository": {
    "type": "git",
    "url": "https://github.com/valentin-baron/delphi-devkit.git"
  },
  "icon": "assets/DelphiHelmet.png",
  "engines": {
    "vscode": "^1.101.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ddk.projects.refresh",
        "title": "Reload from configuration",
        "icon": "$(refresh)",
        "category": "DDK"
      },
      {
        "command": "ddk.projects.discoverProjectPaths",
        "title": "Discover Project Paths",
        "icon": "$(search)",
        "category": "DDK"
      },
      {
        "command": "ddk.projects.addProject",
        "title": "Add Project",
        "icon": "$(add)",
        "category": "DDK"
      },
      {
        "command": "ddk.projects.removeProject",
        "title": "Remove Project",
        "icon": "$(remove)",
        "category": "DDK"
      },
      {
        "command": "ddk.projects.addWorkspace",
        "title": "Add Workspace",
        "icon": "$(add)",
        "category": "DDK"
      },
      {
        "command": "ddk.projects.renameWorkspace",
        "title": "Rename Workspace",
        "icon": "$(edit)",
        "category": "DDK"
      },
      {
        "command": "ddk.projects.removeWorkspace",
        "title": "Remove Workspace",
        "icon": "$(remove)",
        "category": "DDK"
      },
      {
        "command": "ddk.projects.selectProject",
        "title": "Select Project",
        "icon": "$(check)",
        "category": "DDK"
      },
      {
        "command": "ddk.projects.compile",
        "title": "Compile",
        "icon": "$(sync-ignored)",
        "category": "DDK"
      },
      {
        "command": "ddk.projects.recreate",
        "title": "Recreate",
        "icon": "$(sync)",
        "category": "DDK"
      },
      {
        "command": "ddk.projects.showInExplorer",
        "title": "Show in Explorer",
        "icon": "$(folder)",
        "category": "DDK"
      },
      {
        "command": "ddk.projects.openInFileExplorer",
        "title": "Open in File Explorer",
        "icon": "$(folder-opened)",
        "category": "DDK"
      },
      {
        "command": "ddk.projects.runExecutable",
        "title": "Run",
        "icon": "$(play)",
        "category": "DDK"
      },
      {
        "command": "ddk.projects.configureOrCreateIni",
        "title": "Configure/Create .ini",
        "icon": "$(settings-gear)",
        "category": "DDK"
      },
      {
        "command": "ddk.projects.compileAllFromHere",
        "title": "Compile all from here",
        "category": "DDK"
      },
      {
        "command": "ddk.projects.recreateAllFromHere",
        "title": "Recreate all from here",
        "category": "DDK"
      },
      {
        "command": "ddk.projects.compileAllInWorkspace",
        "title": "Compile all in workspace",
        "category": "DDK"
      },
      {
        "command": "ddk.projects.recreateAllInWorkspace",
        "title": "Recreate all in workspace",
        "category": "DDK"
      },
      {
        "command": "ddk.projects.setManualPath",
        "title": "Set Path manually",
        "icon": "$(pencil)",
        "category": "DDK"
      },
      {
        "command": "ddk.projects.compileAllInGroupProject",
        "title": "Compile all in group project",
        "icon": "$(sync-ignored)",
        "category": "DDK"
      },
      {
        "command": "ddk.projects.recreateAllInGroupProject",
        "title": "Recreate all in group project",
        "icon": "$(sync)",
        "category": "DDK"
      },
      {
        "command": "ddk.exportProjects",
        "title": "Export Projects",
        "icon": "$(cloud-upload)",
        "category": "DDK"
      },
      {
        "command": "ddk.importProjects",
        "title": "Import Projects",
        "icon": "$(cloud-download)",
        "category": "DDK"
      },
      {
        "command": "ddk.exportCompilers",
        "title": "Export Compilers",
        "icon": "$(cloud-upload)",
        "category": "DDK"
      },
      {
        "command": "ddk.importCompilers",
        "title": "Import Compilers",
        "icon": "$(cloud-download)",
        "category": "DDK"
      },
      {
        "command": "ddk.projects.editDefaultIni",
        "title": "Edit Default .ini",
        "icon": "$(pencil)",
        "category": "DDK"
      },
      {
        "command": "ddk.projects.selectCompilerConfiguration",
        "title": "Select Delphi Compiler for Group Projects",
        "icon": "$(tools)",
        "category": "DDK"
      },
      {
        "command": "ddk.projects.pickGroupProject",
        "title": "Pick Group Project",
        "icon": "$(file-submodule)",
        "category": "DDK"
      },
      {
        "command": "ddk.projects.unloadGroupProject",
        "title": "Unload Group Project",
        "icon": "$(close)",
        "when": "ddk:isGroupProjectOpened == true",
        "category": "DDK"
      },
      {
        "command": "ddk.projects.cancelCompilation",
        "title": "Cancel Compilation",
        "icon": "$(debug-stop)",
        "category": "DDK"
      },
      {
        "command": "ddk.projects.compileSelectedProject",
        "title": "Compile Selected Project",
        "when": "ddk:isProjectSelected == true",
        "category": "DDK"
      },
      {
        "command": "ddk.projects.recreateSelectedProject",
        "title": "Recreate Selected Project",
        "when": "ddk:isProjectSelected == true",
        "category": "DDK"
      },
      {
        "command": "ddk.projects.runSelectedProject",
        "title": "Run Selected Project",
        "when": "ddk:isProjectSelected == true && ddk:doesSelectedProjectHaveExe == true",
        "category": "DDK"
      },
      {
        "command": "ddk.dfm.swapToDfmPas",
        "title": "Swap .DFM/.PAS",
        "when": "editorTextFocus && (resourceExtname == '.pas' || resourceExtname == '.dfm')",
        "category": "DDK"
      },
      {
        "command": "ddk.projects.setProjectConfiguration",
        "title": "Set Project Configuration",
        "category": "DDK"
      },
      {
        "command": "ddk.projects.setProjectPlatform",
        "title": "Set Project Platform",
        "category": "DDK"
      },
      {
        "command": "ddk.projects.setWorkspaceConfiguration",
        "title": "Set Configuration",
        "icon": "$(symbol-enum)",
        "category": "DDK"
      },
      {
        "command": "ddk.projects.setWorkspacePlatform",
        "title": "Set Platform",
        "icon": "$(device-desktop)",
        "category": "DDK"
      },
      {
        "command": "ddk.projects.setGroupProjectConfiguration",
        "title": "Set Group Project Configuration",
        "icon": "$(symbol-enum)",
        "category": "DDK"
      },
      {
        "command": "ddk.projects.setGroupProjectPlatform",
        "title": "Set Group Project Platform",
        "icon": "$(device-desktop)",
        "category": "DDK"
      },
      {
        "command": "ddk.projects.transferGroupProject",
        "title": "Transfer Group Project to Workspace",
        "icon": "$(files)",
        "category": "DDK"
      },
      {
        "command": "ddk.formatter.editConfig",
        "title": "Edit Formatter Configuration",
        "category": "DDK"
      },
      {
        "command": "ddk.formatter.resetConfig",
        "title": "Reset Formatter Configuration",
        "category": "DDK"
      },
      {
        "command": "ddk.editCompilerConfigurations",
        "title": "Edit Compiler Configurations",
        "category": "DDK"
      },
      {
        "command": "ddk.resetCompilerConfigurations",
        "title": "Reset Compiler Configurations",
        "category": "DDK"
      },
      {
        "command": "ddk.editProjectsData",
        "title": "Edit Projects Data",
        "category": "DDK"
      },
      {
        "command": "ddk.configuration.openItem",
        "title": "Open Configuration Item",
        "category": "DDK"
      }
    ],
    "views": {
      "ddk-projects": [
        {
          "id": "ddk.view.projects.workspaces",
          "name": "Self-Defined Workspaces",
          "icon": "assets/DelphiHelmetLine.svg",
          "canDragAndDrop": true
        },
        {
          "id": "ddk.view.projects.groupProject",
          "name": "Loaded Group Project",
          "icon": "assets/DelphiHelmetLine.svg"
        },
        {
          "id": "ddk.view.configuration",
          "name": "DDK Configuration",
          "icon": "assets/DelphiHelmetLine.svg",
          "visibility": "collapsed"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ddk-projects",
          "title": "Delphi Projects",
          "icon": "assets/DelphiHelmetLine.svg"
        }
      ]
    },
    "menus": {
      "commandPalette": [
        {
          "command": "ddk.projects.refresh",
          "when": "false"
        },
        {
          "command": "ddk.projects.discoverProjectPaths",
          "when": "false"
        },
        {
          "command": "ddk.projects.addProject",
          "when": "false"
        },
        {
          "command": "ddk.projects.removeProject",
          "when": "false"
        },
        {
          "command": "ddk.projects.addWorkspace",
          "when": "false"
        },
        {
          "command": "ddk.projects.renameWorkspace",
          "when": "false"
        },
        {
          "command": "ddk.projects.removeWorkspace",
          "when": "false"
        },
        {
          "command": "ddk.projects.selectProject",
          "when": "false"
        },
        {
          "command": "ddk.projects.compile",
          "when": "false"
        },
        {
          "command": "ddk.projects.recreate",
          "when": "false"
        },
        {
          "command": "ddk.projects.showInExplorer",
          "when": "false"
        },
        {
          "command": "ddk.projects.openInFileExplorer",
          "when": "false"
        },
        {
          "command": "ddk.projects.runExecutable",
          "when": "false"
        },
        {
          "command": "ddk.projects.configureOrCreateIni",
          "when": "false"
        },
        {
          "command": "ddk.projects.compileAllFromHere",
          "when": "false"
        },
        {
          "command": "ddk.projects.recreateAllFromHere",
          "when": "false"
        },
        {
          "command": "ddk.projects.compileAllInWorkspace",
          "when": "false"
        },
        {
          "command": "ddk.projects.recreateAllInWorkspace",
          "when": "false"
        },
        {
          "command": "ddk.projects.setManualPath",
          "when": "false"
        },
        {
          "command": "ddk.projects.setProjectConfiguration",
          "when": "false"
        },
        {
          "command": "ddk.projects.setProjectPlatform",
          "when": "false"
        },
        {
          "command": "ddk.projects.setWorkspaceConfiguration",
          "when": "false"
        },
        {
          "command": "ddk.projects.setWorkspacePlatform",
          "when": "false"
        },
        {
          "command": "ddk.projects.setGroupProjectConfiguration",
          "when": "false"
        },
        {
          "command": "ddk.projects.setGroupProjectPlatform",
          "when": "false"
        },
        {
          "command": "ddk.configuration.openItem",
          "when": "false"
        }
      ],
      "view/title": [
        {
          "command": "ddk.projects.refresh",
          "when": "view == ddk.view.projects.workspaces",
          "group": "navigation"
        },
        {
          "command": "ddk.projects.addWorkspace",
          "when": "view == ddk.view.projects.workspaces",
          "group": "navigation"
        },
        {
          "command": "ddk.importProjects",
          "when": "view == ddk.view.projects.workspaces",
          "group": "navigation"
        },
        {
          "command": "ddk.exportProjects",
          "when": "view == ddk.view.projects.workspaces",
          "group": "navigation"
        },
        {
          "command": "ddk.projects.selectCompilerConfiguration",
          "when": "view == ddk.view.projects.groupProject",
          "group": "navigation"
        },
        {
          "command": "ddk.projects.transferGroupProject",
          "when": "view == ddk.view.projects.groupProject && ddk:isGroupProjectOpened == true",
          "group": "navigation@0"
        },
        {
          "command": "ddk.projects.compileAllInGroupProject",
          "when": "view == ddk.view.projects.groupProject && ddk:isGroupProjectOpened == true",
          "group": "navigation@1"
        },
        {
          "command": "ddk.projects.recreateAllInGroupProject",
          "when": "view == ddk.view.projects.groupProject && ddk:isGroupProjectOpened == true",
          "group": "navigation@2"
        },
        {
          "command": "ddk.projects.pickGroupProject",
          "when": "view == ddk.view.projects.groupProject",
          "group": "navigation@3"
        },
        {
          "command": "ddk.projects.unloadGroupProject",
          "when": "view == ddk.view.projects.groupProject && ddk:isGroupProjectOpened == true",
          "group": "navigation@4"
        },
        {
          "command": "ddk.projects.setGroupProjectConfiguration",
          "when": "view == ddk.view.projects.groupProject && ddk:isGroupProjectOpened == true",
          "group": "navigation@5"
        },
        {
          "command": "ddk.projects.setGroupProjectPlatform",
          "when": "view == ddk.view.projects.groupProject && ddk:isGroupProjectOpened == true",
          "group": "navigation@6"
        }
      ],
      "view/item/context": [
        {
          "command": "ddk.projects.selectProject",
          "when": "view =~ /^ddk\\.view\\.projects.*/ && (viewItem == ddk.context.projects.project || viewItem == ddk.context.projects.projectFile)",
          "group": "1_select@1"
        },
        {
          "command": "ddk.projects.compile",
          "when": "view =~ /^ddk\\.view\\.projects.*/ && (viewItem == ddk.context.projects.project || viewItem == ddk.context.projects.projectFile)",
          "group": "2_compiler@1"
        },
        {
          "command": "ddk.projects.recreate",
          "when": "view =~ /^ddk\\.view\\.projects.*/ && (viewItem == ddk.context.projects.project || viewItem == ddk.context.projects.projectFile)",
          "group": "2_compiler@2"
        },
        {
          "command": "ddk.projects.compileAllFromHere",
          "when": "view =~ /^ddk\\.view\\.projects.*/ && (viewItem == ddk.context.projects.project || viewItem == ddk.context.projects.projectFile)",
          "group": "2_compiler@3"
        },
        {
          "command": "ddk.projects.recreateAllFromHere",
          "when": "view =~ /^ddk\\.view\\.projects.*/ && (viewItem == ddk.context.projects.project || viewItem == ddk.context.projects.projectFile)",
          "group": "2_compiler@3"
        },
        {
          "command": "ddk.projects.compileAllInWorkspace",
          "when": "view == ddk.view.projects.workspaces",
          "group": "2_compiler@4"
        },
        {
          "command": "ddk.projects.recreateAllInWorkspace",
          "when": "view == ddk.view.projects.workspaces",
          "group": "2_compiler@5"
        },
        {
          "command": "ddk.projects.showInExplorer",
          "when": "view =~ /^ddk\\.view\\.projects.*/ && (viewItem == ddk.context.projects.projectFile)",
          "group": "3_file_actions@1"
        },
        {
          "command": "ddk.projects.openInFileExplorer",
          "when": "view =~ /^ddk\\.view\\.projects.*/ && (viewItem == ddk.context.projects.projectFile)",
          "group": "3_file_actions@2"
        },
        {
          "command": "ddk.projects.refresh",
          "when": "view =~ /^ddk\\.view\\.projects.*/ && (viewItem == ddk.context.projects.project || viewItem == ddk.context.projects.projectFile)",
          "group": "3_file_actions@2"
        },
        {
          "command": "ddk.projects.runExecutable",
          "when": "view =~ /^ddk\\.view\\.projects.*/ && (viewItem == ddk.context.projects.project || viewItem == ddk.context.projects.projectFile)",
          "group": "4_exe_actions@1"
        },
        {
          "command": "ddk.projects.configureOrCreateIni",
          "when": "view =~ /^ddk\\.view\\.projects.*/ && (viewItem == ddk.context.projects.project || viewItem == ddk.context.projects.projectFile)",
          "group": "4_exe_actions@2"
        },
        {
          "command": "ddk.projects.renameWorkspace",
          "when": "view == ddk.view.projects.workspaces && viewItem == ddk.context.projects.workspace",
          "group": "5_workspace@1"
        },
        {
          "command": "ddk.projects.removeWorkspace",
          "when": "view == ddk.view.projects.workspaces && viewItem == ddk.context.projects.workspace",
          "group": "5_workspace@2"
        },
        {
          "command": "ddk.projects.setWorkspaceConfiguration",
          "when": "view == ddk.view.projects.workspaces && viewItem == ddk.context.projects.workspace",
          "group": "5_workspace@3"
        },
        {
          "command": "ddk.projects.setWorkspacePlatform",
          "when": "view == ddk.view.projects.workspaces && viewItem == ddk.context.projects.workspace",
          "group": "5_workspace@4"
        },
        {
          "command": "ddk.projects.setWorkspaceConfiguration",
          "when": "view == ddk.view.projects.workspaces && viewItem == ddk.context.projects.workspace",
          "group": "inline@1"
        },
        {
          "command": "ddk.projects.setWorkspacePlatform",
          "when": "view == ddk.view.projects.workspaces && viewItem == ddk.context.projects.workspace",
          "group": "inline@2"
        },
        {
          "command": "ddk.projects.addProject",
          "when": "view == ddk.view.projects.workspaces && viewItem",
          "group": "6_project@1"
        },
        {
          "command": "ddk.projects.removeProject",
          "when": "view == ddk.view.projects.workspaces && (viewItem == ddk.context.projects.project || viewItem == ddk.context.projects.projectFile)",
          "group": "6_project@2"
        },
        {
          "command": "ddk.projects.discoverProjectPaths",
          "when": "viewItem == ddk.context.projects.project",
          "group": "7_paths@1"
        },
        {
          "command": "ddk.projects.setManualPath",
          "when": "viewItem == ddk.context.projects.projectFile",
          "group": "7_paths@2"
        }
      ]
    },
    "languages": [
      {
        "id": "ddk.dfm",
        "extensions": [
          ".dfm"
        ],
        "aliases": [
          "Delphi Form",
          "Delphi DFM"
        ]
      },
      {
        "id": "ddk.compiler",
        "aliases": [
          "DDK Compiler Output"
        ]
      }
    ],
    "configuration": {
      "title": "DDK - Delphi Development Kit",
      "properties": {
        "ddk.compiler.encoding": {
          "type": "string",
          "default": "oem",
          "enum": [
            "oem",
            "utf-8",
            "utf-16le",
            "utf-16be",
            "utf-32le",
            "utf-32be",
            "windows-1250",
            "windows-1251",
            "windows-1252",
            "windows-1253",
            "windows-1254",
            "windows-1255",
            "windows-1256",
            "windows-1257",
            "windows-1258",
            "iso-8859-1",
            "iso-8859-2",
            "iso-8859-3",
            "iso-8859-4",
            "iso-8859-5",
            "iso-8859-6",
            "iso-8859-7",
            "iso-8859-8",
            "iso-8859-9",
            "iso-8859-10",
            "iso-8859-13",
            "iso-8859-14",
            "iso-8859-15",
            "shift_jis",
            "euc-jp",
            "euc-kr",
            "gbk",
            "big5",
            "koi8-r",
            "koi8-u"
          ],
          "enumDescriptions": [
            "Auto-detect using the system OEM codepage (recommended)",
            "UTF-8 (Unicode)",
            "UTF-16 Little Endian",
            "UTF-16 Big Endian",
            "UTF-32 Little Endian",
            "UTF-32 Big Endian",
            "Windows-1250 (Central European)",
            "Windows-1251 (Cyrillic)",
            "Windows-1252 (Western European) — Default for Delphi",
            "Windows-1253 (Greek)",
            "Windows-1254 (Turkish)",
            "Windows-1255 (Hebrew)",
            "Windows-1256 (Arabic)",
            "Windows-1257 (Baltic)",
            "Windows-1258 (Vietnamese)",
            "ISO 8859-1 (Latin-1 Western European)",
            "ISO 8859-2 (Latin-2 Central European)",
            "ISO 8859-3 (Latin-3 South European)",
            "ISO 8859-4 (Latin-4 North European)",
            "ISO 8859-5 (Cyrillic)",
            "ISO 8859-6 (Arabic)",
            "ISO 8859-7 (Greek)",
            "ISO 8859-8 (Hebrew)",
            "ISO 8859-9 (Turkish)",
            "ISO 8859-10 (Nordic)",
            "ISO 8859-13 (Baltic Rim)",
            "ISO 8859-14 (Celtic)",
            "ISO 8859-15 (Latin-9)",
            "Shift JIS (Japanese)",
            "EUC-JP (Japanese)",
            "EUC-KR (Korean)",
            "GBK (Chinese Simplified)",
            "Big5 (Chinese Traditional)",
            "KOI8-R (Russian)",
            "KOI8-U (Ukrainian)"
          ],
          "description": "Encoding used by the Delphi compiler output. Determines how raw compiler bytes are decoded before display."
        },
        "ddk.projects.configPlatformDisplay": {
          "type": "string",
          "default": "aboveFiles",
          "enum": [
            "aboveFiles",
            "belowFiles",
            "off"
          ],
          "enumDescriptions": [
            "Show Configurations and Platforms above project files",
            "Show Configurations and Platforms below project files",
            "Do not show Configurations and Platforms in the project tree"
          ],
          "description": "Controls where build configurations and target platforms are displayed in the project tree."
        }
      }
    },
    "grammars": [
      {
        "language": "ddk.compiler",
        "scopeName": "text.output.delphi-compiler",
        "path": "./config/languages/grammar/compiler-output.json"
      }
    ],
    "configurationDefaults": {
      "editor.tokenColorCustomizations": {
        "textMateRules": [
          {
            "scope": "invalid.illegal.error.delphi",
            "settings": {
              "foreground": "#ff6b6b"
            }
          },
          {
            "scope": "markup.warning.delphi",
            "settings": {
              "foreground": "#fdcb6e"
            }
          },
          {
            "scope": "markup.hint.delphi",
            "settings": {
              "foreground": "#74b9ff"
            }
          },
          {
            "scope": "markup.info.delphi",
            "settings": {
              "foreground": "#55a3ff"
            }
          },
          {
            "scope": "constant.other.error-code.delphi",
            "settings": {
              "foreground": "#a29bfe"
            }
          },
          {
            "scope": "string.other.filepath.delphi",
            "settings": {
              "foreground": "#00b894"
            }
          },
          {
            "scope": "constant.numeric.line-number.delphi",
            "settings": {
              "foreground": "#ffeaa7"
            }
          },
          {
            "scope": "constant.numeric.column-number.delphi",
            "settings": {
              "foreground": "#ffeaa7"
            }
          },
          {
            "scope": "constant.other.timestamp.delphi",
            "settings": {
              "foreground": "#636e72"
            }
          },
          {
            "scope": "string.unquoted.message.delphi",
            "settings": {
              "foreground": "#dfe6e9"
            }
          },
          {
            "scope": "entity.name.type.quoted-identifier.delphi",
            "settings": {
              "foreground": "#e17cf5",
              "fontStyle": "italic"
            }
          },
          {
            "scope": "keyword.other.banner.delphi",
            "settings": {
              "foreground": "#74b9ff"
            }
          },
          {
            "scope": "markup.success.banner.delphi",
            "settings": {
              "foreground": "#00b894"
            }
          },
          {
            "scope": "markup.error.banner.delphi",
            "settings": {
              "foreground": "#ff6b6b"
            }
          },
          {
            "scope": "markup.cancelled.banner.delphi",
            "settings": {
              "foreground": "#e17055"
            }
          },
          {
            "scope": "markup.multi.banner.delphi",
            "settings": {
              "foreground": "#a29bfe"
            }
          },
          {
            "scope": "markup.project.banner.delphi",
            "settings": {
              "foreground": "#636e72"
            }
          }
        ]
      }
    },
    "mcpServerDefinitionProviders": [
      {
        "id": "ddk.mcp",
        "label": "DDK - Delphi Development Kit"
      }
    ],
    "keybindings": [
      {
        "command": "ddk.dfm.swapToDfmPas",
        "key": "alt+f12",
        "mac": "alt+f12",
        "when": "editorTextFocus && (resourceExtname == '.pas' || resourceExtname == '.dfm')"
      },
      {
        "command": "ddk.projects.compileSelectedProject",
        "key": "ctrl+f9",
        "when": "ddk:isProjectSelected == true"
      },
      {
        "command": "ddk.projects.recreateSelectedProject",
        "key": "shift+f9",
        "when": "ddk:isProjectSelected == true"
      },
      {
        "command": "ddk.projects.runSelectedProject",
        "key": "f9",
        "when": "ddk:isProjectSelected == true && ddk:doesSelectedProjectHaveExe == true"
      },
      {
        "command": "ddk.projects.cancelCompilation",
        "key": "ctrl+f2",
        "when": "ddk:isCompiling == true"
      }
    ]
  },
  "prettier": {
    "overrides": [
      {
        "files": "*.ts",
        "options": {
          "printWidth": 150,
          "singleQuote": true,
          "trailingComma": "none",
          "useTabs": false,
          "tabWidth": 2,
          "semi": true,
          "bracketSpacing": true,
          "bracketSameLine": true
        }
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "prepackage": "node -e \"const fs=require('fs');fs.copyFileSync('../README.md','README.md');fs.copyFileSync('../CHANGELOG.md','CHANGELOG.md');fs.copyFileSync('../LICENSE','LICENSE');\"",
    "compile": "cd .. && cargo build && cd vscode_extension && npm run check-types && npm run lint && node esbuild.js",
    "watch": "cd ../vscode_extension && npm-run-all -p watch:*",
    "watch:esbuild": "cd ../vscode_extension && node esbuild.js --watch",
    "watch:tsc": "cd ../vscode_extension && tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "full-package": "cd .. && cargo build --release && cd vscode_extension && npm run package",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/mock-fs": "^4.13.4",
    "@types/node": "20.x",
    "@types/vscode": "^1.101.0",
    "@types/xmldom": "^0.1.34",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.25.3",
    "eslint": "^9.25.1",
    "eslint-plugin-unused-imports": "^4.1.4",
    "mock-fs": "^5.5.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@types/uuid": "^10.0.0",
    "@xmldom/xmldom": "^0.9.8",
    "minimatch": "^10.0.3",
    "reflect-metadata": "^0.2.2",
    "uuid": "^11.1.0",
    "vscode-languageclient": "^9.0.1"
  }
}
